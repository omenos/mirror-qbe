# make sure large consts are lowered
# without an offset
#  i.e. not movq $9223372036854775807, 64(%rax)

export function w $main() {
@_0
	%_1 =w call $myfunc(l 1, l 2, l 3, l 4, l 5, l 6, l 7, l 8, l 9223372036854775807)
	ret 0
}

